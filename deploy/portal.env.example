# SyncRow Portal service environment — install to /etc/syncrow/portal.env
# Owned by root, mode 600. Loaded by systemd (EnvironmentFile). NOT in git.
#
# The app reads these via os.getenv(); systemd-provided values take precedence
# over any .env file (load_env_file uses setdefault), so no .env is needed in
# the code directory.

# --- InfluxDB (now LOCAL to this box — talk to it over loopback, not the public IP) ---
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=__PASTE_YOUR_INFLUX_TOKEN_HERE__
INFLUX_ORG=__YOUR_ORG__
INFLUX_ORG_ID=__YOUR_ORG_ID__
INFLUX_BUCKET=syncrow

# --- Portal serving ---
# Must match the domain nginx serves (used for --allow-websocket-origin).
PORTAL_DOMAIN=portal.example.com

# Signs the auth session cookie. Generate with:  openssl rand -hex 32
COOKIE_SECRET=__RUN_openssl_rand_hex_32__

# Where the parquet cache is written (must be under a ReadWritePaths dir).
CACHE_DIR=/opt/syncrow/SyncRow_Portal/.cache
